## Server
PORT=3000
MONGO_URI=your_mongodb_connection_string
CORS_ORIGIN=http://localhost:5173

## App auth JWT
ACCESS_TOKEN_SECRET=your_app_access_token_secret
REFRESH_TOKEN_SECRET=your_app_refresh_token_secret
JWT_SECRET=optional_fallback_secret

## Google login OAuth
CLIENT_ID=your_google_login_client_id
CLIENT_SECRET=your_google_login_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

## Email via Gmail OAuth
EMAIL_USER=your_gmail_address
EMAIL_CLIENT_ID=your_email_oauth_client_id
EMAIL_CLIENT_SECRET=your_email_oauth_client_secret
EMAIL_REFRESH_TOKEN=your_gmail_refresh_token
EMAIL_ACCESS_TOKEN=optional_current_gmail_access_token

## Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=**********

## Email / auth timings
OTP_EXPIRY_MINUTES=10
RESET_PASSWORD_EXPIRY_MINUTES=15
RESET_PASSWORD_URL=http://localhost:5173/reset-password
