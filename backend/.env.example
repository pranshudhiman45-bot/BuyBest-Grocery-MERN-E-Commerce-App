## Server
PORT=3000
MONGO_URI=your_mongodb_connection_string
CORS_ORIGIN=https://buy-best-grocery-mern-e-commerce-ap.vercel.app,http://localhost:5173
# Use * to allow any origin. With credentialed requests, the server will
# reflect the requesting origin instead of sending a literal wildcard.
FRONTEND_URL=https://buy-best-grocery-mern-e-commerce-ap.vercel.app

## App auth JWT
ACCESS_TOKEN_SECRET=your_app_access_token_secret
REFRESH_TOKEN_SECRET=your_app_refresh_token_secret
JWT_SECRET=optional_fallback_secret

## Google login OAuth
CLIENT_ID=your_google_login_client_id
CLIENT_SECRET=your_google_login_client_secret
GOOGLE_CALLBACK_URL=https://buybest-grocery-mern-e-commerce-app.onrender.com/api/auth/google/callback

## Email via Gmail OAuth
EMAIL_USER=your_gmail_address
EMAIL_CLIENT_ID=your_email_oauth_client_id
EMAIL_CLIENT_SECRET=your_email_oauth_client_secret
EMAIL_REFRESH_TOKEN=your_gmail_refresh_token
EMAIL_ACCESS_TOKEN=optional_current_gmail_access_token

## Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=**********

## Stripe
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

## Email / auth timings
OTP_EXPIRY_MINUTES=10
RESET_PASSWORD_EXPIRY_MINUTES=15
RESET_PASSWORD_URL=https://buy-best-grocery-mern-e-commerce-ap.vercel.app/reset-password
